alias runw='poetry run python start.py'
alias runl='poetry run python start.py --local'
alias ae='poetry run python -m tools.assemblage_edit'
alias mapv='poetry run python -m tools.map_visualizer'
alias brelease='poetry run bumpversion release'
alias bpatch='poetry run bumpversion --no-tag patch'
alias bminor='poetry run bumpversion --no-tag minor'
alias bmajor='poetry run bumpversion --no-tag major'
alias atlas='poetry run python -m tools.build_atlas  static/img/oryx_ur/$tile.png static/img/oryx_ur/$tile.txt static/img/oryx_ur/$tile.json'
alias tile_ids='poetry run python -m tools.make_tile_ids static/img/oryx_ur'
alias typing='poetry run mypy'
alias rg="rg --iglob '!static/js/pixi*' --iglob '!typeshed'"
alias black='poetry run black .'
alias vulture='poetry run python -m vulture --exclude data/,__pycache__/,templates/,typeshed/,.vscode/,.idea/,node_modules/,build/,dist/,static/,.git/,.serverless/ . whitelist.py'
