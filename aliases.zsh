alias run='poetry run python start.py'
alias runp='rm start.prof; poetry run python -m cProfile -o start.prof start.py; snakeviz start.prof'
alias ae='poetry run python -m tools.assemblage_edit'
alias mapv='poetry run python -m tools.map_visualizer'
alias brelease='poetry run bumpversion release'
alias bpatch='poetry run bumpversion --no-tag patch'
alias bminor='poetry run bumpversion --no-tag minor'
alias bmajor='poetry run bumpversion --no-tag major'
alias typing='poetry run mypy'
alias black='poetry run black .'
alias vulture='poetry run python -m vulture --exclude data/,__pycache__/,.vscode/,.idea/,.git/ . whitelist.py'
